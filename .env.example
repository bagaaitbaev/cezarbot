# ================================================================
# Обязательные переменные — без них бот не запустится
# ================================================================

# Telegram bot token from @BotFather
BOT_TOKEN=

# ================================================================
# Важные переменные — без них часть функций не будет работать
# ================================================================

# ID операторской группы Telegram (уведомления о новых бронях,
# команды /bugun /today /operator). Получить ID: добавить бота
# в группу, сделать бронь — ID появится в логах Railway.
# ВАЖНО: прописать в Railway → Variables после каждого пересоздания сервиса!
OPERATOR_TELEGRAM_IDS=

# WhatsApp operator chats for notifications in the unofficial WhatsApp Web bot.
# Use international phone numbers without "+" or full chat ids, comma-separated.
# Example: OPERATOR_WHATSAPP_IDS=77001234567,77007654321
OPERATOR_WHATSAPP_IDS=

# Optional WhatsApp Web session name. Keep one stable value after scanning QR.
WHATSAPP_CLIENT_ID=cezarbot

# Optional fixed WhatsApp Web HTML version. Change only if WhatsApp Web startup breaks.
WHATSAPP_WEB_VERSION_URL=https://raw.githubusercontent.com/wppconnect-team/wa-version/main/html/2.3000.1039181464-alpha.html

# Admin panel for staff bookings.
ADMIN_PORT=3000
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-long-random-string
# Optional multi-user admin access. Format:
# username:password:display name:role;username2:password2:display name:role
# If ADMIN_USERS is set, it replaces ADMIN_USER/ADMIN_PASSWORD.
ADMIN_USERS=admin:change-this-password:Админ:admin

# Ссылка для отправки отзыва на 2GIS
TWO_GIS_REVIEW_URL=

# ================================================================
# Опциональные переменные
# ================================================================

# Часовой пояс (Kazakhstan, UTC+5)
TZ=Asia/Almaty

# Приветственная картинка (путь от корня проекта или абсолютный)
# Ещё проще: положите файл assets/welcome.jpg
# WELCOME_IMAGE=assets/welcome.jpg
