# Telegram bot token from @BotFather
BOT_TOKEN=

# Optional: Asia/Almaty (Kazakhstan, UTC+5)
TZ=Asia/Almaty

# Optional: приветственная картинка (путь от корня проекта или абсолютный)
# Ещё проще: положите файл assets/welcome.jpg
# WELCOME_IMAGE=assets/welcome.jpg

# Операторлар: Telegram user id (немесе топ id), үтірмен. Жаңа бронь туралы хабарлама + /bugun, /today, /operator
# ID алу: @userinfobot немесе топта /start кейін логта chat id
# OPERATOR_TELEGRAM_IDS=123456789,-1001234567890
